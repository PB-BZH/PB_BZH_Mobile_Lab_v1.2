<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PB_BZH_Mobile_Lab.UI.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="">

   
    <ScrollView>
        <VerticalStackLayout Padding="22,10" Spacing="8">
            <Label Text="Profil" />
            <Picker
                x:Name="pickerProfiles"
                Title="Choisir un profil"
                SelectedIndexChanged="PickerProfiles_SelectedIndexChanged" />

            <Image Source="banner_pb_bzh.png"       
                   Aspect="AspectFit"
                   Margin="10,10,10,8"                   
                   HorizontalOptions="Fill" />

            <Label
                Text="License Generator Mobile"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="1">
                <Label
                    Text="Produit *"
                    FontSize="11"
                    TextColor="#444444"
                    Margin="0,0,0,-4" />

                <Entry
                    x:Name="txtProductId"
                    Placeholder="Produit" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="1">
                <Label
                    Text="Identifiant licence *"
                    FontSize="11"
                    TextColor="#444444"
                    Margin="0,0,0,-4" />

                <Entry
                    x:Name="txtLicenseId"
                    Placeholder="Identifiant licence" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="1">
                <Label
                    Text="Nom du client *"
                    FontSize="11"
                    TextColor="#444444"
                    Margin="0,0,0,-4" />
                
                <Entry
                    x:Name="txtCustomerName"
                    Placeholder="Client" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="1">
                <Label
                    Text="Site du client"
                    FontSize="11"
                    TextColor="#444444"
                    Margin="0,0,0,-4" />
                <Entry
                    x:Name="txtSite"
                    Placeholder="Site" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="1">
                <Label
                    Text="Email du contact"
                    FontSize="11"
                    TextColor="#444444"
                    Margin="0,0,0,-4" />
                <Entry
                    x:Name="txtEmailContact"
                    Placeholder="Email" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="1">
                <Label
                    Text="Hash de la machine *"
                    FontSize="11"
                    TextColor="#444444"
                    Margin="0,0,0,-4" />
                <Entry
                    x:Name="txtMachineHash"
                    Placeholder="Machine hash" />
            </VerticalStackLayout>

            <Grid ColumnDefinitions="150,35,200" ColumnSpacing="2">
                <DatePicker 
                    x:Name="dtpValidUntil"
                    Format="dd/MM/yyyy"
                    Grid.Column="0" />
                <CheckBox 
                    x:Name="chkValidUnlimited" 
                    Grid.Column="1"/>
                <Label
                    Text="Licence illimitée" 
                    VerticalOptions="Center" 
                    Grid.Column="2"/>
            </Grid>
            <Grid ColumnDefinitions="150,35,200" ColumnSpacing="2">
                <DatePicker 
                    x:Name="dtpMaintenanceUntil" 
                    Format="dd/MM/yyyy"
                    Grid.Column="0"/>

                <CheckBox 
                    x:Name="chkMaintenanceUnlimited" 
                    Grid.Column="1"/>
                <Label 
                    Text="Maintenance illimitée" 
                    VerticalOptions="Center" 
                    Grid.Column="2"/>
            </Grid>

            <Button
                Text="Générer la licence"
                Clicked="BtnGenerateLicense_Clicked" />

            <Grid
                ColumnDefinitions="*,*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="6"
                RowSpacing="6">

                <Button
                    Text="Nouveau"
                    Clicked="BtnNewProfile_Clicked" />

                <Button
                    Grid.Column="1"
                    Text="Enregistrer"
                    Clicked="BtnSaveProfile_Clicked" />

                <Button
                    Grid.Column="2"
                    Text="Partager"
                    Clicked="BtnShareLicense_Clicked" />

                <Button
                    Grid.Row="1"
                    Text="Profils"
                    Clicked="BtnProfileActions_Clicked" />

                <Button
                    Grid.Row="1"
                    Grid.Column="1"
                    Text="Clé privée"
                    Clicked="BtnPrivateKeyActions_Clicked" />

                <Button
                    x:Name="btnToggleResult"
                    Grid.Row="1"
                    Grid.Column="2"
                    Text="JSON"
                    Clicked="BtnToggleResult_Clicked" />
            </Grid>
            <Label   
                    x:Name="lblPrivateKeyStatus"
                    Text="Clé privée : non vérifiée"
                    FontSize="12"
                    HorizontalOptions="Center" />

            <Editor
                x:Name="txtResult"
                IsVisible="False"
                HeightRequest="500"
                IsReadOnly="True"
                AutoSize="Disabled"
                FontSize="11" />            

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>