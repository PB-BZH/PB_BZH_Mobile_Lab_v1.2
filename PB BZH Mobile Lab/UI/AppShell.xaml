<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PB_BZH_Mobile_Lab.UI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PB_BZH_Mobile_Lab.UI"
    Title="PB_BZH_Mobile_Lab">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    
    <MenuItem Text="Exporter les profils"
          Clicked="OnExportProfilesClicked" />

    <MenuItem Text="Importer les profils"
          Clicked="OnImportProfilesClicked" />
</Shell>
