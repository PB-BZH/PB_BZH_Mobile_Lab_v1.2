<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PB_BZH_Mobile_Lab.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="">

   
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">
            <Label Text="Profil" />
            <Picker
                x:Name="pickerProfiles"
                Title="Choisir un profil"
                SelectedIndexChanged="PickerProfiles_SelectedIndexChanged" />

            <Image Source="banner_pb_bzh.png"       
                   Aspect="AspectFit"
                   Margin="10,10,10,8"                   
                   HorizontalOptions="Fill" />

            <Label
                Text="License Generator Mobile"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Entry
                x:Name="txtProductId"
                Placeholder="Produit" />

            <Entry
                x:Name="txtLicenseId"
                Placeholder="Identifiant licence" />

            <Entry
                x:Name="txtCustomerName"
                Placeholder="Client" />

            <Entry
                x:Name="txtSite"
                Placeholder="Site" />

            <Entry
                x:Name="txtEmailContact"
                Placeholder="Email" />

            <Entry
                x:Name="txtMachineHash"
                Placeholder="Machine hash" />

            <Grid ColumnDefinitions="150,35,200" ColumnSpacing="2">
                <DatePicker 
                    x:Name="dtpValidUntil"
                    Format="dd/MM/yyyy"
                    Grid.Column="0" />
                <CheckBox 
                    x:Name="chkValidUnlimited" 
                    Grid.Column="1"/>
                <Label
                    Text="Licence illimitée" 
                    VerticalOptions="Center" 
                    Grid.Column="2"/>
            </Grid>
            <Grid ColumnDefinitions="150,35,200" ColumnSpacing="2">
                <DatePicker 
                    x:Name="dtpMaintenanceUntil" 
                    Format="dd/MM/yyyy"
                    Grid.Column="0"/>

                <CheckBox 
                    x:Name="chkMaintenanceUnlimited" 
                    Grid.Column="1"/>
                <Label 
                    Text="Maintenance illimitée" 
                    VerticalOptions="Center" 
                    Grid.Column="2"/>
            </Grid>

            <Button
                Text="Générer la licence"
                Clicked="BtnGenerateLicense_Clicked" />

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button
                    Text="Nouveau"
                    Clicked="BtnNewProfile_Clicked" />
                
                <Button
                    Grid.Column="1"
                    Text="Charger"
                    Clicked="BtnLoadProfile_Clicked" />

                <Button
                    Grid.Column="2"
                    Text="Enregistrer"
                    Clicked="BtnSaveProfile_Clicked" />
            </Grid>
            <Grid ColumnDefinitions="*,450" ColumnSpacing="10">
                <Button
                    Grid.Column="0"
                    Text="Supprimer le profil"
                    Clicked="BtnDeleteProfile_Clicked"
                    BackgroundColor="#8A1F1F"
                    TextColor="White" />

                <Button
                    Grid.Column="1"
                    Text="Supprimer la clé privée"
                    Clicked="BtnDeletePrivateKey_Clicked"
                    BackgroundColor="#8A1F1F"
                    TextColor="White" />
            </Grid>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                
                <Button
                    Text="Partager"
                    Clicked="BtnShareLicense_Clicked" />

                <Button        
                    x:Name="btnToggleResult"
                    Grid.Column="1"
                    Text="JSON"
                    Clicked="BtnToggleResult_Clicked" />
                <Button
                    Grid.Column="2"
                    Text="Importer la clé privée"
                    Clicked="BtnImportPrivateKey_Clicked" />
                <Label   
                    Grid.Column="2"
                    x:Name="lblPrivateKeyStatus"
                    Text="Clé privée : non vérifiée"
                    FontSize="12"
                    HorizontalOptions="Center" />
            </Grid>
            
            <Editor
                x:Name="txtResult"
                IsVisible="False"
                HeightRequest="500"
                IsReadOnly="True"
                AutoSize="Disabled"
                FontSize="11" />            

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>